---
import { waLink } from '@/utils/whatsapp';
const waUrl = waLink();
---
<footer class="bg-slate-900 text-white pt-16 pb-0">
  <div class="wrap">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 pb-12 border-b border-white/10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4 group">
          <img src="/images/logo.svg" alt="BodyNation" width="44" height="44"
            class="w-11 h-11 object-contain rounded-xl" />
          <div class="flex flex-col leading-none">
            <span class="text-lg font-black tracking-tight">
              <span class="text-white">BODY</span><span class="text-orange-500">NATION</span>
            </span>
            <span class="text-[0.48rem] font-semibold tracking-[0.18em] uppercase text-white/35 mt-0.5">Sports &amp; Nutrition</span>
          </div>
        </a>
        <p class="text-sm text-white/45 leading-relaxed mb-4 max-w-xs">
          Your trusted supplement store in Bibwewadi, Pune. Authentic products, honest advice, competitive pricing.
        </p>
        <a href="https://instagram.com/bodynation_protein_shop" target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 text-sm font-semibold text-orange-400 hover:text-orange-300 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          @bodynation_protein_shop
        </a>
      </div>

      <!-- Navigate -->
      <div>
        <h4 class="text-[0.65rem] font-bold tracking-widest uppercase text-white/40 mb-4">Navigate</h4>
        <ul class="flex flex-col gap-2.5">
          {[['/', 'Home'], ['/products', 'Shop'], ['/offers', 'Offers'], ['/about', 'About'], ['/contact', 'Contact']].map(([href, label]) => (
            <li><a href={href} class="text-sm text-white/45 hover:text-white transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Products -->
      <div>
        <h4 class="text-[0.65rem] font-bold tracking-widest uppercase text-white/40 mb-4">Products</h4>
        <ul class="flex flex-col gap-2.5">
          {[
            ['/products?cat=protein',     'Whey Protein'],
            ['/products?cat=creatine',    'Creatine'],
            ['/products?cat=mass-gainer', 'Mass Gainers'],
            ['/products?cat=pre-workout', 'Pre Workout'],
            ['/products?cat=vitamins',    'Vitamins'],
            ['/products?cat=fat-burner',  'Fat Burners'],
          ].map(([href, label]) => (
            <li><a href={href} class="text-sm text-white/45 hover:text-white transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-[0.65rem] font-bold tracking-widest uppercase text-white/40 mb-4">Contact Us</h4>
        <ul class="flex flex-col gap-3">
          <li>
            <a href="tel:+919623300461" class="text-sm text-white/45 hover:text-white transition-colors">
              +91 96233 00461
            </a>
          </li>
          <li>
            <a href={waUrl} target="_blank" rel="noopener" class="text-sm text-[#4ade80] hover:text-[#86efac] transition-colors font-medium">
              WhatsApp Order
            </a>
          </li>
          <li class="text-sm text-white/35 leading-relaxed">
            Shop No 105, Kapil Upvan Plaza<br />
            Lake Town Road, Bibwewadi<br />
            Pune – 411037
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 py-5">
      <p class="text-xs text-white/20">© {new Date().getFullYear()} BodyNation Sports &amp; Nutrition. All rights reserved.</p>
      <p class="text-xs text-white/20">Authentic supplements · Bibwewadi, Pune</p>
    </div>
  </div>
</footer>

---
import type { CollectionEntry } from 'astro:content';
import { waLink } from '@/utils/whatsapp';

interface Props {
  product: CollectionEntry<'products'>;
}
const { product } = Astro.props;
const { name, category, badge, badgeColor, image, benefit, price, priceLabel, whatsappMsg, inStock } = product.data;

const badgeClasses: Record<string, string> = {
  orange: 'bg-orange-600 text-white',
  blue:   'bg-blue-800 text-white',
  green:  'bg-green-600 text-white',
};

const categoryLabels: Record<string, string> = {
  protein:     'Protein',
  creatine:    'Strength',
  'mass-gainer': 'Mass & Bulk',
  'pre-workout': 'Energy & Focus',
  vitamins:    'Health',
  'fat-burner': 'Fat Loss',
};

const tintClasses: Record<string, string> = {
  protein:       'bg-blue-50',
  creatine:      'bg-orange-50',
  'mass-gainer': 'bg-slate-100',
  'pre-workout': 'bg-purple-50',
  vitamins:      'bg-green-50',
  'fat-burner':  'bg-red-50',
};

const waUrl = waLink(whatsappMsg);
---
<article class="rv group bg-white border border-slate-200 rounded-3xl overflow-hidden flex flex-col hover:-translate-y-1.5 hover:shadow-brand-xl hover:border-slate-300 transition-all duration-300">

  <!-- Image area -->
  <div class:list={['relative h-52 flex items-center justify-center overflow-hidden', tintClasses[category] ?? 'bg-slate-50']}>
    <img
      src={image}
      alt={name}
      width="200"
      height="200"
      class="w-40 h-40 object-contain group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
    />
    <!-- Fallback placeholder shown if image fails -->
    <div class="hidden w-36 h-44 rounded-2xl border-2 border-dashed border-slate-300 flex-col items-center justify-center gap-2 bg-white/70">
      <span class="text-3xl opacity-40">🏋️</span>
      <span class="text-[0.6rem] font-bold tracking-wider uppercase text-slate-400 text-center px-2">Product Photo</span>
    </div>

    {badge && (
      <div class:list={['absolute top-3 left-3 text-[0.65rem] font-bold tracking-wide uppercase px-2.5 py-1 rounded-full', badgeClasses[badgeColor ?? 'orange']]}>
        {badge}
      </div>
    )}

    {!inStock && (
      <div class="absolute inset-0 bg-white/70 flex items-center justify-center">
        <span class="text-xs font-bold uppercase tracking-widest text-slate-400 border border-slate-300 px-3 py-1 rounded-full bg-white">Out of Stock</span>
      </div>
    )}
  </div>

  <!-- Body -->
  <div class="p-5 flex flex-col flex-1">
    <div class="text-[0.65rem] font-bold tracking-widest uppercase text-orange-600 mb-1">{categoryLabels[category] ?? category}</div>
    <h3 class="text-lg font-extrabold text-slate-900 tracking-tight leading-tight mb-2">{name}</h3>
    <p class="text-xs text-slate-500 leading-relaxed flex-1 mb-4">{benefit}</p>

    <!-- Footer -->
    <div class="flex items-center justify-between gap-2 pt-3 border-t border-slate-100">
      <div>
        <strong class="text-xl font-black text-slate-900 tracking-tight leading-none block">
          {priceLabel ?? `₹${price.toLocaleString('en-IN')}`}
        </strong>
        <span class="text-[0.65rem] text-slate-400 font-medium">starting price</span>
      </div>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class:list={['btn-wa btn-sm flex-shrink-0', !inStock && 'opacity-50 pointer-events-none']}
        aria-label={`Order ${name} on WhatsApp`}
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Order
      </a>
    </div>
  </div>
</article>

---
import { getCollection } from 'astro:content';

const allReviews = await getCollection('testimonials');
const reviews = allReviews[0].data as Array<{
  name: string; initials: string; location: string;
  text: string; rating: number; order: number;
}>;
const sorted = [...reviews].sort((a, b) => a.order - b.order);

const avatarColors = ['bg-blue-800', 'bg-orange-600', 'bg-purple-600', 'bg-green-600'];
---
<section class="py-20 bg-white">
  <div class="wrap">
    <div class="text-center rv mb-12">
      <div class="sh-label justify-center">Customer Reviews</div>
      <h2 class="sh-title">Trusted by Pune Athletes</h2>
      <p class="sh-sub mx-auto">Real reviews from real gym members who trust BodyNation for their supplements.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {sorted.map((r, i) => (
        <div class="rv bg-slate-50 border border-slate-200 rounded-2xl p-6 hover:bg-white hover:shadow-brand-md hover:-translate-y-1 transition-all duration-300">
          <div class="text-4xl font-black text-blue-800/15 leading-none mb-1">"</div>
          <div class="flex gap-0.5 mb-3">
            {Array.from({ length: r.rating }).map(() => (
              <span class="text-amber-400 text-sm">★</span>
            ))}
          </div>
          <p class="text-sm text-slate-500 leading-relaxed mb-5 flex-1">{r.text}</p>
          <div class="flex items-center gap-3">
            <div class:list={['w-10 h-10 rounded-full text-white text-xs font-bold flex items-center justify-center flex-shrink-0', avatarColors[i % avatarColors.length]]}>
              {r.initials}
            </div>
            <div>
              <div class="text-sm font-bold text-slate-900">{r.name}</div>
              <div class="text-xs text-slate-400">{r.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import { waLink } from '@/utils/whatsapp';
const waUrl = waLink('Hi Akash, I want to visit BodyNation. What are your store timings?');
const mapsUrl = 'https://maps.google.com/?q=Kapil+Upvan+Plaza+Lake+Town+Road+Bibwewadi+Pune';
---
<section class="py-20 bg-slate-50" id="contact">
  <div class="wrap">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">

      <!-- Left: Info -->
      <div class="rv-l">
        <div class="sh-label">Find Us</div>
        <h2 class="sh-title">Visit Our Store</h2>
        <p class="text-base text-slate-500 leading-relaxed mb-8">
          Located in the heart of Bibwewadi — steps from Gravity Fitness Club. Walk in or WhatsApp your order before you visit.
        </p>

        <div class="flex flex-col gap-4 mb-8">
          <!-- Address -->
          <div class="flex gap-4 items-start bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-brand-sm hover:border-slate-300 transition-all duration-200">
            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-xl flex-shrink-0">📍</div>
            <div>
              <div class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Address</div>
              <address class="text-sm text-slate-600 not-italic leading-relaxed font-medium">
                Shop No 105, Kapil Upvan Plaza<br/>
                Lake Town Road, Near Gravity Fitness Club<br/>
                Bibwewadi, Pune – 411037
              </address>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex gap-4 items-start bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-brand-sm hover:border-slate-300 transition-all duration-200">
            <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-xl flex-shrink-0">📞</div>
            <div>
              <div class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Phone / WhatsApp</div>
              <a href="tel:+919623300461" class="text-sm font-bold text-blue-700 hover:text-blue-800 transition-colors">
                +91 96233 00461
              </a>
            </div>
          </div>

          <!-- Instagram -->
          <div class="flex gap-4 items-start bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-brand-sm hover:border-slate-300 transition-all duration-200">
            <div class="w-10 h-10 rounded-xl bg-orange-50 flex items-center justify-center text-xl flex-shrink-0">📸</div>
            <div>
              <div class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Instagram</div>
              <a
                href="https://instagram.com/bodynation_protein_shop"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-bold text-orange-600 hover:text-orange-700 transition-colors"
              >
                @bodynation_protein_shop
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex gap-4 items-start bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-brand-sm hover:border-slate-300 transition-all duration-200">
            <div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center text-xl flex-shrink-0">🕙</div>
            <div>
              <div class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Store Hours</div>
              <div class="text-sm font-medium text-slate-600">Mon – Sat: 10:00 AM – 9:00 PM</div>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href={waUrl} target="_blank" rel="noopener" class="btn-wa btn-lg">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Chat on WhatsApp
          </a>
          <a href={mapsUrl} target="_blank" rel="noopener" class="btn-outline btn-lg">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Get Directions
          </a>
        </div>
      </div>

      <!-- Right: Map card -->
      <div class="rv-r">
        <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-brand-md">
          <!-- Map visual -->
          <div class="h-64 relative flex items-center justify-center overflow-hidden"
            style="background:linear-gradient(135deg,#e8f0fe 0%,#eef2ff 100%)">
            <!-- Grid pattern -->
            <div class="absolute inset-0"
              style="background-image:linear-gradient(rgba(26,58,143,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(26,58,143,0.05) 1px,transparent 1px);background-size:32px 32px">
            </div>
            <!-- Pin -->
            <div class="relative z-10 flex flex-col items-center gap-3">
              <div class="w-16 h-16 rounded-full bg-blue-800 flex items-center justify-center text-2xl text-white map-pulse">
                📍
              </div>
              <div class="text-xs font-bold text-blue-800 bg-white border border-slate-200 px-3 py-1.5 rounded-full shadow-brand-sm">
                BodyNation Sports &amp; Nutrition
              </div>
            </div>
          </div>

          <!-- Address strip -->
          <div class="p-5 flex items-center justify-between gap-4 flex-wrap">
            <div>
              <p class="text-sm font-bold text-slate-900 mb-0.5">Shop No 105, Kapil Upvan Plaza</p>
              <p class="text-xs text-slate-500">Lake Town Road, Bibwewadi, Pune – 411037</p>
            </div>
            <a href={mapsUrl} target="_blank" rel="noopener" class="btn-blue btn-sm flex-shrink-0">
              Open Maps
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

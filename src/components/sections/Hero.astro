---
import { waLink } from '@/utils/whatsapp';
const waUrl = waLink('Hi Akash, I want to order supplements from BodyNation.');
---
<section id="hero" class="relative min-h-screen flex items-center pt-24 pb-16 overflow-hidden bg-white">

  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Dot grid -->
    <div class="absolute inset-0"
      style="background-image:radial-gradient(circle,rgba(26,58,143,0.07) 1.5px,transparent 1.5px);background-size:38px 38px;mask-image:radial-gradient(ellipse 70% 80% at 80% 50%,black 0%,transparent 70%)">
    </div>
    <!-- Blue blob -->
    <div class="absolute -top-32 -right-24 w-[600px] h-[600px] rounded-full"
      style="background:radial-gradient(circle,rgba(26,58,143,0.07) 0%,transparent 70%)">
    </div>
    <!-- Orange blob -->
    <div class="absolute -bottom-24 -left-24 w-[400px] h-[400px] rounded-full"
      style="background:radial-gradient(circle,rgba(232,98,10,0.06) 0%,transparent 70%)">
    </div>
  </div>

  <div class="wrap relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Copy -->
      <div>
        <!-- Location badge -->
        <div class="inline-flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-orange-600 border border-orange-200 bg-orange-50 px-4 py-2 rounded-full mb-7 animate-fade-down">
          <span class="w-2 h-2 rounded-full bg-orange-500 animate-blink"></span>
          📍 Bibwewadi, Pune — 411037
        </div>

        <!-- Headline -->
        <h1 class="text-5xl sm:text-6xl xl:text-7xl font-black tracking-tight leading-[1.02] text-slate-900 mb-6 animate-fade-up" style="animation-delay:0.1s">
          Authentic<br/>
          <span class="text-orange-600">Supplements</span><br/>
          for <span class="text-blue-800">Strength</span><br/>
          &amp; Performance
        </h1>

        <p class="text-lg text-slate-500 leading-relaxed max-w-lg mb-8 animate-fade-up" style="animation-delay:0.2s">
          Premium whey protein, creatine and fitness supplements — 100% genuine, sourced from verified distributors. Trusted by hundreds of athletes in Pune.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 mb-10 animate-fade-up" style="animation-delay:0.3s">
          <a href="/products" class="btn-blue btn-lg">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            Browse Products
          </a>
          <a href={waUrl} target="_blank" rel="noopener" class="btn-wa btn-lg">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp Order
          </a>
          <a href="/contact" class="btn-ghost btn-lg">Find Store</a>
        </div>

        <!-- Stats -->
        <div class="flex flex-wrap gap-8 pt-8 border-t border-slate-100 animate-fade-up" style="animation-delay:0.4s">
          {[
            { num: '500+', label: 'Happy Customers' },
            { num: '50+',  label: 'Brands in Stock' },
            { num: '100%', label: 'Authentic' },
            { num: '5+',   label: 'Years of Trust' },
          ].map(s => (
            <div class="flex flex-col gap-0.5">
              <span class="text-2xl font-black text-blue-800 tracking-tight leading-none">{s.num}</span>
              <span class="text-xs font-medium text-slate-400">{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Logo showcase + mini cards (desktop) -->
      <div class="hidden lg:block">
        <div class="relative bg-slate-50 border border-slate-200 rounded-3xl p-8 overflow-hidden">
          <!-- Top accent -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-800 to-orange-600 rounded-t-3xl"></div>

          <!-- Logo -->
          <div class="w-full h-44 rounded-2xl bg-gradient-to-br from-blue-800 to-blue-700 flex items-center justify-center mb-6 overflow-hidden">
            <img
              src="/images/store.webp"
              alt="BodyNation Sports & Nutrition"
              class="w-full h-full object-cover"
            />
          </div>

          <!-- Mini stat cards -->
          <div class="grid grid-cols-2 gap-3">
            {[
              { icon: '✅', val: '100%',  label: 'Authentic',  accent: 'blue' },
              { icon: '🏆', val: '500+',  label: 'Customers',  accent: 'none' },
              { icon: '⚡', val: '50+',   label: 'Brands',     accent: 'orange' },
              { icon: '📦', val: 'Sealed', label: 'Packaging', accent: 'none' },
            ].map((c, i) => (
              <div class:list={[
                'rounded-2xl p-4 border transition-transform hover:-translate-y-1 duration-300',
                i === 0 ? 'bg-blue-50 border-blue-200' :
                i === 2 ? 'bg-orange-50 border-orange-200' :
                'bg-white border-slate-200',
                i % 2 === 1 ? 'mt-3' : ''
              ]} style={`animation:float ${4 + i * 0.4}s ease-in-out infinite`}>
                <div class="text-2xl mb-1">{c.icon}</div>
                <div class:list={[
                  'text-xl font-black tracking-tight leading-none',
                  i === 0 ? 'text-blue-800' : i === 2 ? 'text-orange-600' : 'text-slate-900'
                ]}>{c.val}</div>
                <div class="text-xs text-slate-400 font-medium mt-0.5">{c.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

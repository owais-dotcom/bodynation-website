---
import { getCollection } from 'astro:content';
import { waLink } from '@/utils/whatsapp';

const allOffers = await getCollection('offers');
const activeOffers = allOffers
  .filter(o => o.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---
<section class="py-20 bg-slate-50" id="offers">
  <div class="wrap">
    <div class="rv mb-12">
      <div class="sh-label">Special Deals</div>
      <h2 class="sh-title">Bundle Offers &amp; Deals</h2>
      <p class="sh-sub">Stack smarter, save more. Curated combos for every fitness goal.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {activeOffers.map((offer, i) => {
        const { title, tag, tagEmoji, originalPrice, salePrice, items, whatsappMsg, featured } = offer.data;
        const saving = originalPrice - salePrice;
        const savePct = Math.round((saving / originalPrice) * 100);
        const waUrl = waLink(whatsappMsg);
        return (
          <div class:list={[
            'rv relative bg-white border rounded-3xl p-7 flex flex-col gap-5 hover:-translate-y-1 hover:shadow-brand-lg transition-all duration-300 overflow-hidden',
            featured ? 'border-orange-200 bg-gradient-to-b from-orange-50/60 to-white' : 'border-slate-200'
          ]}>
            <!-- Top accent line -->
            <div class:list={[
              'absolute top-0 left-0 right-0 h-1 rounded-t-3xl',
              featured ? 'bg-gradient-to-r from-orange-600 to-orange-400' : 'bg-gradient-to-r from-blue-800 to-blue-600'
            ]}></div>

            <div>
              <div class:list={[
                'text-xs font-bold tracking-widest uppercase mb-3',
                featured ? 'text-orange-600' : 'text-blue-700'
              ]}>
                {tagEmoji} {tag}
              </div>
              <h3 class="text-xl font-extrabold text-slate-900 tracking-tight leading-tight mb-2">{title}</h3>
              <p class="text-sm text-slate-500 leading-relaxed" set:html={offer.body}></p>
            </div>

            <!-- Items -->
            <ul class="flex flex-col gap-2">
              {items.map(item => (
                <li class="flex items-center gap-2.5 text-sm font-medium text-slate-600">
                  <span class="w-4 h-4 rounded-full bg-green-100 border border-green-300 flex-shrink-0 flex items-center justify-center text-[0.55rem] text-green-600 font-bold">✓</span>
                  {item}
                </li>
              ))}
            </ul>

            <!-- Price -->
            <div class="flex items-baseline gap-3">
              <span class="text-sm text-slate-400 line-through font-medium">₹{originalPrice.toLocaleString('en-IN')}</span>
              <span class="text-4xl font-black text-slate-900 tracking-tight leading-none">₹{salePrice.toLocaleString('en-IN')}</span>
              <span class="text-xs font-bold text-green-700 bg-green-100 border border-green-200 px-2 py-0.5 rounded-full">Save {savePct}%</span>
            </div>

            <a
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[featured ? 'btn-orange' : 'btn-outline', 'text-center justify-center']}
            >
              {featured ? 'Grab This Deal →' : 'Get This Stack →'}
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { waLink } from '@/utils/whatsapp';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const products = await getCollection('products');
  return products.map(p => ({
    params: { slug: p.data.slug },
    props:  { product: p },
  }));
};

const { product } = Astro.props;
const { name, category, badge, image, benefit, price, priceLabel, whatsappMsg, inStock } = product.data;
const { Content } = await product.render();
const waUrl = waLink(whatsappMsg);

const categoryLabels: Record<string, string> = {
  protein: 'Protein', creatine: 'Strength', 'mass-gainer': 'Mass & Bulk',
  'pre-workout': 'Energy & Focus', vitamins: 'Health', 'fat-burner': 'Fat Loss',
};
---
<BaseLayout
  title={`${name} – BodyNation Sports & Nutrition`}
  description={benefit}
>
  <div class="pt-32 pb-20">
    <div class="wrap">
      <!-- Breadcrumb -->
      <nav class="text-xs text-slate-400 mb-8 flex items-center gap-2" aria-label="Breadcrumb">
        <a href="/" class="hover:text-blue-700 transition-colors">Home</a>
        <span>›</span>
        <a href="/products" class="hover:text-blue-700 transition-colors">Products</a>
        <span>›</span>
        <span class="text-slate-600 font-medium">{name}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Product image -->
        <div class="bg-slate-50 border border-slate-200 rounded-3xl p-10 flex items-center justify-center min-h-80">
          <img
            src={image}
            alt={name}
            width="300"
            height="300"
            class="w-64 h-64 object-contain"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div class="hidden w-48 h-60 rounded-2xl border-2 border-dashed border-slate-300 flex-col items-center justify-center gap-3 bg-white">
            <span class="text-5xl opacity-30">🏋️</span>
            <span class="text-xs font-bold tracking-wider uppercase text-slate-400">Product Photo</span>
          </div>
        </div>

        <!-- Details -->
        <div>
          <div class="text-xs font-bold tracking-widest uppercase text-orange-600 mb-2">{categoryLabels[category] ?? category}</div>
          <h1 class="text-3xl lg:text-4xl font-black text-slate-900 tracking-tight leading-tight mb-4">{name}</h1>
          <p class="text-base text-slate-500 leading-relaxed mb-6">{benefit}</p>

          <!-- Price + CTA -->
          <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 mb-6">
            <div class="flex items-center justify-between gap-4 mb-5">
              <div>
                <strong class="text-3xl font-black text-slate-900 tracking-tight">
                  {priceLabel ?? `₹${price.toLocaleString('en-IN')}`}
                </strong>
                <span class="text-sm text-slate-400 font-medium block mt-0.5">starting price · WhatsApp for exact quote</span>
              </div>
              {badge && (
                <span class="text-xs font-bold tracking-wide uppercase px-3 py-1.5 rounded-full bg-orange-600 text-white">{badge}</span>
              )}
            </div>

            <a
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class:list={['btn-wa w-full justify-center py-4 text-base rounded-2xl', !inStock && 'opacity-50 pointer-events-none']}
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {inStock ? 'Order on WhatsApp' : 'Out of Stock'}
            </a>
          </div>

          <!-- Guarantees -->
          <div class="flex flex-wrap gap-3">
            {['✅ 100% Authentic', '📦 Sealed Packaging', '⚡ Fast WhatsApp Response'].map(g => (
              <span class="text-xs font-semibold text-slate-600 bg-slate-100 border border-slate-200 px-3 py-1.5 rounded-full">{g}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Product description content -->
      <div class="mt-14 max-w-3xl">
        <h2 class="text-xl font-bold text-slate-900 mb-6 pb-4 border-b border-slate-200">Product Details</h2>
        <div class="prose prose-slate prose-headings:font-bold prose-headings:text-slate-900 prose-p:text-slate-600 prose-li:text-slate-600 max-w-none">
          <Content />
        </div>
      </div>

      <!-- Back -->
      <div class="mt-12">
        <a href="/products" class="btn-ghost">← Back to All Products</a>
      </div>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProductCard from '@/components/sections/ProductCard.astro';

const allProducts = await getCollection('products');
const sorted = [...allProducts].sort((a, b) => a.data.order - b.data.order);

const categories = [
  { value: 'all',         label: 'All Products' },
  { value: 'protein',     label: 'Whey Protein' },
  { value: 'creatine',    label: 'Creatine' },
  { value: 'mass-gainer', label: 'Mass Gainers' },
  { value: 'pre-workout', label: 'Pre Workout' },
  { value: 'vitamins',    label: 'Vitamins' },
  { value: 'fat-burner',  label: 'Fat Burners' },
];
---
<BaseLayout
  title="All Supplements – BodyNation Sports & Nutrition, Pune"
  description="Browse our full range of authentic supplements in Bibwewadi, Pune. Whey protein, creatine, pre-workout, mass gainers, vitamins and fat burners."
>
  <!-- Header -->
  <div class="pt-32 pb-12 bg-slate-50 border-b border-slate-200">
    <div class="wrap">
      <div class="sh-label">Our Products</div>
      <h1 class="sh-title">All Supplements</h1>
      <p class="sh-sub">Every product batch-verified before sale. 100% authentic from day one.</p>
    </div>
  </div>

  <div class="py-12 bg-white">
    <div class="wrap">

      <!-- Category filter tabs -->
      <div class="flex flex-wrap gap-2 mb-10" id="cat-tabs" role="tablist" aria-label="Filter by category">
        {categories.map(cat => (
          <button
            class:list={[
              'cat-btn px-4 py-2 rounded-xl text-sm font-semibold border transition-all duration-200 cursor-pointer',
              cat.value === 'all'
                ? 'bg-blue-800 text-white border-blue-800'
                : 'bg-white text-slate-600 border-slate-200 hover:border-blue-300 hover:text-blue-800'
            ]}
            data-cat={cat.value}
            role="tab"
            aria-selected={cat.value === 'all' ? 'true' : 'false'}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="products-grid">
        {sorted.map(product => (
          <div data-cat={product.data.category} class="product-item">
            <ProductCard product={product} />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-20">
        <div class="text-4xl mb-3">🔍</div>
        <p class="text-slate-500 font-medium">No products found in this category.</p>
        <button class="cat-btn mt-4 btn-outline btn-sm" data-cat="all">Show All</button>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const tabs    = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const items   = document.querySelectorAll<HTMLElement>('.product-item');
  const empty   = document.getElementById('empty-state')!;

  function filter(cat: string) {
    // Update tab styles
    tabs.forEach(btn => {
      const active = btn.dataset.cat === cat;
      btn.classList.toggle('bg-blue-800',  active);
      btn.classList.toggle('text-white',   active);
      btn.classList.toggle('border-blue-800', active);
      btn.classList.toggle('bg-white',     !active);
      btn.classList.toggle('text-slate-600', !active);
      btn.classList.toggle('border-slate-200', !active);
      btn.setAttribute('aria-selected', String(active));
    });

    // Show/hide products
    let visible = 0;
    items.forEach(item => {
      const show = cat === 'all' || item.dataset.cat === cat;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    empty.classList.toggle('hidden', visible > 0);
  }

  tabs.forEach(btn => btn.addEventListener('click', () => filter(btn.dataset.cat ?? 'all')));

  // Handle URL ?cat= param on load
  const urlCat = new URLSearchParams(window.location.search).get('cat') ?? 'all';
  filter(urlCat);
</script>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Offers from '@/components/sections/Offers.astro';
---
<BaseLayout
  title="Bundle Offers & Deals – BodyNation Sports & Nutrition"
  description="Save big with BodyNation's supplement bundles. Whey + Creatine, Beginner Stack, Cut & Energy — great combos at the best prices in Pune."
>
  <div class="pt-32 pb-10 bg-slate-50 border-b border-slate-200">
    <div class="wrap">
      <div class="sh-label">Special Deals</div>
      <h1 class="sh-title">Bundle Offers</h1>
      <p class="sh-sub">Stack smarter, save more. All bundles available to order on WhatsApp.</p>
    </div>
  </div>
  <Offers />
</BaseLayout>

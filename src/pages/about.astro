---
import BaseLayout from '@/layouts/BaseLayout.astro';
import About from '@/components/sections/About.astro';
import TrustBand from '@/components/sections/TrustBand.astro';
---
<BaseLayout
  title="About BodyNation – Authentic Supplements in Bibwewadi, Pune"
  description="Learn about BodyNation Sports & Nutrition. 5+ years, 500+ customers, 50+ brands. Your trusted supplement store in Bibwewadi, Pune."
>
  <div class="pt-32 pb-10 bg-slate-50 border-b border-slate-200">
    <div class="wrap">
      <div class="sh-label">Our Story</div>
      <h1 class="sh-title">About BodyNation</h1>
      <p class="sh-sub">5+ years of trust. 500+ happy customers. 50+ brands stocked. All genuine.</p>
    </div>
  </div>
  <About />
  <TrustBand />
</BaseLayout>

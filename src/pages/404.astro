---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found – BodyNation" noindex={true}>
  <div class="min-h-screen flex items-center justify-center pt-24 pb-16">
    <div class="text-center px-6">
      <div class="text-8xl font-black text-slate-100 mb-4 leading-none">404</div>
      <h1 class="text-2xl font-bold text-slate-900 mb-3">Page not found</h1>
      <p class="text-slate-500 mb-8 max-w-sm mx-auto">Looks like this page doesn't exist. Head back to the store.</p>
      <div class="flex justify-center flex-wrap gap-3">
        <a href="/" class="btn-blue">← Back to Home</a>
        <a href="/products" class="btn-outline">Browse Products</a>
      </div>
    </div>
  </div>
</BaseLayout>

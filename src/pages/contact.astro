  description="Visit BodyNation at Shop No 105, Kapil Upvan Plaza, Lake Town Road, Bibwewadi, Pune 411037. Call or WhatsApp +91 96233 00461."
>
  <div class="pt-32 pb-10 bg-slate-50 border-b border-slate-200">
    <div class="wrap">
      <div class="sh-label">Get In Touch</div>
      <h1 class="sh-title">Contact Us</h1>
      <p class="sh-sub">Visit us in Bibwewadi or order on WhatsApp — we respond fast.</p>
    </div>
  </div>
  <Location />
